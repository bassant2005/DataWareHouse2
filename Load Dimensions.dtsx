                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    Longitude,
    Latitude,
    CASE 
        WHEN Latitude BETWEEN 40.70 AND 40.80 AND Longitude BETWEEN -74.02 AND -73.93 THEN 'Manhattan'
        WHEN Latitude BETWEEN 40.57 AND 40.70 AND Longitude BETWEEN -74.04 AND -73.83 THEN 'Brooklyn'
        WHEN Latitude BETWEEN 40.54 AND 40.74 AND Longitude BETWEEN -73.96 AND -73.70 THEN 'Queens'
        WHEN Latitude BETWEEN 40.79 AND 40.92 AND Longitude BETWEEN -73.93 AND -73.76 THEN 'Bronx'
        WHEN Latitude BETWEEN 40.47 AND 40.65 AND Longitude BETWEEN -74.26 AND -74.03 THEN 'Staten Island'
        ELSE 'Unknown'
    END AS Borough,
    CONCAT('Zone_', ROUND(Latitude, 2), '_', ROUND(Longitude, 2)) AS ZoneLabel
FROM (
    SELECT pickup_longitude AS Longitude, pickup_latitude AS Latitude FROM dbo.stg_trips
    UNION
    SELECT dropoff_longitude, dropoff_latitude FROM dbo.stg_trips
) AS AllLocations
WHERE Longitude IS NOT NULL AND Latitude IS NOT NULL</property>
