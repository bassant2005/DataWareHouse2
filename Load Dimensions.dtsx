          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Dim_Location')&#xA;BEGIN&#xA;    CREATE TABLE Dim_Location (&#xA;        LocationKey INT IDENTITY(1,1) PRIMARY KEY,&#xA;        PickupLongitude FLOAT NOT NULL,&#xA;        PickupLatitude FLOAT NOT NULL,&#xA;        DropoffLongitude FLOAT NOT NULL,&#xA;        DropoffLatitude FLOAT NOT NULL,&#xA;        PickupZone VARCHAR(50),&#xA;        DropoffZone VARCHAR(50),&#xA;        Borough VARCHAR(30),&#xA;        DistanceClass VARCHAR(20)&#xA;    );&#xA;END&#xA;&#xA;TRUNCATE TABLE Dim_Location;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
