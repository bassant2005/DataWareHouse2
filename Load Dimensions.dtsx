                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT 
    passenger_count,
    CASE 
        WHEN passenger_count = 1 THEN 'Alone'
        WHEN passenger_count &lt;= 2 THEN 'Couple'
        WHEN passenger_count &lt;= 4 THEN 'Family'
        ELSE 'Group'
    END AS passenger_group
FROM NYC_Taxi_DWH.dbo.stg_trips
WHERE passenger_count IS NOT NULL</property>
