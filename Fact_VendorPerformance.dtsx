      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{8EFA78C5-62B9-49BB-9A91-91F200EF64D3}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="create if not exist"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6E893D88-2858-45D2-959B-33CF2D2AF230}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (&#xA;    SELECT * FROM sys.tables &#xA;    WHERE name = 'Fact_VendorPerformance'&#xA;)&#xA;BEGIN&#xA;    CREATE TABLE dbo.Fact_VendorPerformance (&#xA;        vendor_key            INT,&#xA;        date_key              INT,&#xA;        total_trips           INT,&#xA;        avg_trip_duration_sec FLOAT,&#xA;        avg_passenger_count   FLOAT&#xA;    );&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{4FEA0D67-2634-4E53-A474-0CCE3F74A1A9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6E893D88-2858-45D2-959B-33CF2D2AF230}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.Fact_VendorPerformance &#xA;(vendor_key, date_key, total_trips, avg_trip_duration_sec, avg_passenger_count)&#xA;SELECT&#xA;    DV.VendorKey,&#xA;    DD.DateKey,&#xA;    COUNT(*)                                AS total_trips,&#xA;    AVG(CAST(s.trip_duration AS FLOAT))     AS avg_trip_duration_sec,&#xA;    AVG(CAST(s.passenger_count AS FLOAT))   AS avg_passenger_count&#xA;FROM dbo.stg_trips s&#xA;JOIN dbo.Dim_Vendor DV &#xA;    ON s.vendor_id = DV.VendorID&#xA;JOIN dbo.Dim_Date DD &#xA;    ON CAST(s.pickup_datetime AS DATE) = DD.FullDate&#xA;GROUP BY DV.VendorKey, DD.DateKey;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\truncate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1AEFFCCE-83F8-4757-94BE-CF1A7877479A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="truncate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6E893D88-2858-45D2-959B-33CF2D2AF230}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dbo.Fact_VendorPerformance;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
