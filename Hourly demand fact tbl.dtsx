  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Create if not exist"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{727B4D0C-8131-4B44-B669-E1B7AC8E5CE4}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Create if not exist"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{29103C2C-E674-470A-A1BE-77540BCA3331}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT * FROM sys.tables WHERE name = 'Fact_HourlyDemand')&#xA;BEGIN&#xA;    CREATE TABLE Fact_HourlyDemand (&#xA;        HourlyDemandKey INT IDENTITY(1,1) PRIMARY KEY,&#xA;        DateKey INT,&#xA;        TimeKey INT,&#xA;        trip_count INT,&#xA;        avg_duration_sec FLOAT,&#xA;        total_passengers INT&#xA;    );&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Fact_HourlyDemand"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{40389002-16C9-4D4A-A320-AB3994820CF5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Fact_HourlyDemand"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{29103C2C-E674-470A-A1BE-77540BCA3331}"
          SQLTask:SqlStatementSource="INSERT INTO Fact_HourlyDemand (DateKey, TimeKey, trip_count, avg_duration_sec, total_passengers)&#xA;SELECT &#xA;    dd.DateKey,&#xA;    tt.TimeKey,&#xA;    COUNT(*) AS trip_count,&#xA;    AVG(stg.trip_duration * 1.0) AS avg_duration_sec,&#xA;    SUM(stg.passenger_count) AS total_passengers&#xA;FROM NYC_Taxi_STG.dbo.stg_trips stg&#xA;INNER JOIN Dim_Date dd ON CAST(stg.pickup_datetime AS DATE) = dd.FullDate&#xA;INNER JOIN Dim_Time tt ON DATEPART(HOUR, stg.pickup_datetime) = tt.Hour &#xA;                        AND DATEPART(MINUTE, stg.pickup_datetime) = tt.Minute&#xA;GROUP BY dd.DateKey, tt.TimeKey;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate Fact_HourlyDemand"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{87465DCB-0398-4665-B8A4-A5F5490E8F9C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Fact_HourlyDemand"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{29103C2C-E674-470A-A1BE-77540BCA3331}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE Fact_HourlyDemand;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
